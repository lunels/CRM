generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  COMPLETED
  CANCELLED
}

model Customer {
  id         String   @id @default(cuid())
  firstName  String
  lastName   String?
  company    String?
  email      String   @unique
  phone      String
  address    String?
  city       String?
  postalCode String?
  country    String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  orders     Order[]

  @@index([firstName, lastName, email, phone])
}

model Product {
  id          String      @id @default(cuid())
  name        String
  sku         String      @unique
  description String?
  price       Decimal
  stock       Int         @default(0)
  category    String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]

  @@index([name, sku, category])
}

model Order {
  id          String       @id @default(cuid())
  orderNumber String       @unique
  customerId  String
  date        DateTime
  status      OrderStatus  @default(PENDING)
  subtotal    Decimal
  tax         Decimal
  total       Decimal
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  customer    Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items       OrderItem[]

  @@index([orderNumber, status, date])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  productId  String
  quantity   Int
  unitPrice  Decimal
  lineTotal  Decimal
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId, productId])
}
